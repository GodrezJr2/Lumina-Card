# ══════════════════════════════════════════════════════════════
#  .env.example — salin ke .env dan isi dengan nilai asli
#  JANGAN commit .env ke Git!
# ══════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
# 
# [LOCAL DEVELOPMENT — XAMPP/MySQL]
# DATABASE_URL="mysql://root:@localhost:3306/wedding_gms"
#
# [PRODUCTION — TiDB Cloud]
# Host  : gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000
# DB    : test
# User  : 3uKpfCHHD7scBxm.root
# Format: mysql://USER:PASSWORD@HOST:PORT/DB_NAME?sslaccept=strict
#
DATABASE_URL="mysql://3uKpfCHHD7scBxm.root:PASSWORD@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/test?sslaccept=strict"

# ── Next.js ────────────────────────────────────────────────────
# Secret untuk enkripsi session — generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti_dengan_string_random_panjang_min_32_karakter"

# URL publik aplikasi (tanpa trailing slash)
# Local:      http://localhost:3001
# Production: https://nama-app.vercel.app
NEXTAUTH_URL="https://nama-app.vercel.app"
